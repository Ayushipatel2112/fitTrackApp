@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset Password - FitTrack</title>
    <link rel="stylesheet" href="~/css/App.css" asp-append-version="true" />
    <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body class="auth-body">
    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-header">
                <div class="logo">
                    <i data-lucide="activity" size="32" color="var(--primary)"></i>
                    <span>FitTrack</span>
                </div>
                <h2>Reset Password</h2>
                <p>Set a new password for your account</p>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">@ViewBag.Error</div>
            }

            <form method="post" action="/Account/ResetPassword">
                @Html.AntiForgeryToken()
                <input type="hidden" name="email" value="@ViewBag.Email" />
                
                <div class="form-group">
                    <label>Email Address</label>
                    <input type="text" value="@ViewBag.Email" disabled />
                </div>

                <div class="form-group">
                    <label><i data-lucide="lock" size="16"></i> New Password</label>
                    <input type="password" name="newPassword" required minlength="6" />
                </div>

                <div class="form-group">
                    <label><i data-lucide="lock" size="16"></i> Confirm Password</label>
                    <input type="password" name="confirmPassword" required minlength="6" />
                </div>
                
                <button type="submit" class="btn-primary w-100">Reset Password</button>
            </form>
        </div>
    </div>
    <script>lucide.createIcons();</script>
</body>
</html>
