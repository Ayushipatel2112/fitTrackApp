@model FitnessAppMVC.Models.FitnessService

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Create Service";
}

<div class="admin-data-container narrow">
    <div class="header-with-action">
        <div>
            <h1 class="page-title">Create New Service</h1>
            <p class="page-subtitle">Add a new fitness service to the platform.</p>
        </div>
        <a asp-action="Index" class="btn-outline">Back to List</a>
    </div>

    <div class="data-card form-card">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <div class="form-group">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-input" placeholder="e.g. Workout Planner" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-input" rows="4" placeholder="Briefly describe what this service provides..."></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="IconName" class="form-label">Icon Name (Lucide)</label>
                <input asp-for="IconName" class="form-input" placeholder="e.g. dumbbell, utensils, moon, bar-chart-3" />
                <small class="form-helper">Use any icon name from lucide.dev</small>
                <span asp-validation-for="IconName" class="text-danger"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-primary w-full">Create Service</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
