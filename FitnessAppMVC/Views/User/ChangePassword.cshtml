@{
    Layout = "_UserLayout";
    ViewData["Title"] = "Change Password";
}
<link rel="stylesheet" href="~/css/Tracker.css" asp-append-version="true" />

<div class="tracker-container">
    <div class="tracker-header">
        <div>
            <h1><i data-lucide="lock" size="28"></i> Change Password</h1>
            <p>Update your account password</p>
        </div>
        <a href="/User/Profile" class="btn-outline"><i data-lucide="arrow-left" size="18"></i> Back to Profile</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success"><i data-lucide="check-circle" size="18"></i> @TempData["Success"]</div>
    }
    @if (ViewBag.Error != null)
    {
        <div class="alert alert-error"><i data-lucide="alert-circle" size="18"></i> @ViewBag.Error</div>
    }

    <div class="form-card">
        <form method="post" action="/User/ChangePassword">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label>Current Password *</label>
                <input type="password" name="currentPassword" placeholder="••••••••" required />
            </div>
            <div class="form-group">
                <label>New Password * (min 6 characters)</label>
                <input type="password" name="newPassword" placeholder="••••••••" minlength="6" required />
            </div>
            <div class="form-group">
                <label>Confirm New Password *</label>
                <input type="password" name="confirmPassword" placeholder="••••••••" required />
            </div>
            <div class="form-actions">
                <button type="submit" class="btn-submit">
                    <i data-lucide="lock" size="18"></i> Change Password
                </button>
            </div>
        </form>
    </div>
</div>
@section Scripts {<script>lucide.createIcons();</script>}
